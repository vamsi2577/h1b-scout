{
  "manifest_version": 3,
  "name": "H1B Scout",
  "version": "0.2.8",
  "description": "See H-1B and PERM sponsorship history for any employer - right from the job post. Supports Greenhouse, Workday, Lever, Ashby, LinkedIn, HigherEdJobs, hiring.cafe, Dice, and embedded ATS boards.",
  "permissions": ["sidePanel", "tabs", "storage", "scripting", "clipboardWrite"],
  "host_permissions": [
    "https://*.greenhouse.io/*",
    "https://*.myworkdayjobs.com/*",
    "https://*.workdayjobs.com/*",
    "https://jobs.lever.co/*",
    "https://jobs.ashbyhq.com/*",
    "https://www.linkedin.com/*",
    "https://www.higheredjobs.com/*",
    "https://higheredjobs.com/*",
    "https://hiring.cafe/*",
    "https://www.dice.com/*",
    "https://dice.com/*",
    "https://api.github.com/*",
    "https://github.com/*",
    "https://objects.githubusercontent.com/*",
    "https://boards-api.greenhouse.io/*"
  ],
  "optional_host_permissions": [
    "<all_urls>"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none';"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.greenhouse.io/*",
        "https://*.myworkdayjobs.com/*",
        "https://*.workdayjobs.com/*",
        "https://jobs.lever.co/*",
        "https://jobs.ashbyhq.com/*",
        "https://www.linkedin.com/jobs/*",
        "https://www.linkedin.com/preload/*",
        "https://www.higheredjobs.com/*",
        "https://higheredjobs.com/*",
        "https://hiring.cafe/*",
        "https://www.dice.com/*",
        "https://dice.com/*"
      ],
      "js": [
        "src/shared/normalization.js",
        "src/content/signals-extractor.js",
        "src/content/extractors/common.js",
        "src/content/extractors/greenhouse.js",
        "src/content/extractors/workday.js",
        "src/content/extractors/lever.js",
        "src/content/extractors/ashby.js",
        "src/content/extractors/linkedin.js",
        "src/content/extractors/higheredjobs.js",
        "src/content/extractors/hiringcafe.js",
        "src/content/extractors/dice.js",
        "src/content/job-extractor.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": [
        "https://www.linkedin.com/jobs/search/*",
        "https://www.linkedin.com/jobs/collections/*",
        "https://www.linkedin.com/jobs/recommended/*",
        "https://*.greenhouse.io/*",
        "https://www.higheredjobs.com/*",
        "https://higheredjobs.com/*",
        "https://hiring.cafe/*",
        "https://www.dice.com/jobs*",
        "https://dice.com/jobs*"
      ],
      "js": [
        "src/content/badgers/common.js",
        "src/content/badgers/linkedin.js",
        "src/content/badgers/greenhouse.js",
        "src/content/badgers/higheredjobs.js",
        "src/content/badgers/hiringcafe.js",
        "src/content/badgers/dice.js",
        "src/content/badge-injector.js"
      ],
      "css": ["src/content/badge.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "side_panel": {
    "default_path": "src/sidepanel/panel.html"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "H1B Scout",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "web_accessible_resources": []
}

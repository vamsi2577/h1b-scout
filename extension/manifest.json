{
  "manifest_version": 3,
  "name": "H1B Scout",
  "version": "0.2.0",
  "description": "See H-1B and PERM sponsorship history for any employer — right from the job post. Supports Greenhouse, Workday, Lever, Ashby, LinkedIn, and embedded ATS boards.",
  "permissions": ["sidePanel", "tabs", "storage", "scripting"],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none';"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://boards.greenhouse.io/*",
        "https://*.greenhouse.io/*",
        "https://*.myworkdayjobs.com/*",
        "https://*.workdayjobs.com/*",
        "https://jobs.lever.co/*",
        "https://jobs.ashbyhq.com/*",
        "https://www.linkedin.com/jobs/*",
        "https://www.linkedin.com/preload/*"
      ],
      "js": [
        "src/shared/normalization.js",
        "src/content/signals-extractor.js",
        "src/content/job-extractor.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "side_panel": {
    "default_path": "src/sidepanel/panel.html"
  },
  "action": {
    "default_title": "H1B Scout"
  },
  "web_accessible_resources": []
}
